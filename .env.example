# Copy to repo root as `.env` — loaded by Django (backend_django.settings) and Vite.
# The separate `backend/.env` is only for the Node/Express app in `backend/`; it is not used by Django.

# Required
DJANGO_SECRET_KEY=your-secret-key-here

# Optional - Development settings
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - SQLite (default, no config needed)
# For PostgreSQL, uncomment and configure:
# DB_NAME=economic_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS / CSRF - Frontend URLs (comma-separated)
# Vite in this repo runs on port 8080 by default.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:3000,http://127.0.0.1:8080
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:3000,http://127.0.0.1:8080

# API Keys (optional)
GEMINI_API_KEY=
GROQ_API_KEY=
DOC_PROCESSING_USE_GROQ=false
DOC_PROCESSING_GROQ_MODEL=llama-3.1-8b-instant

# Frontend -> Django API integration
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_ECONOMIC_API_ENDPOINT=/api/economic
VITE_ECONOMIC_API_ENABLED=true
